{
  "manifest_version": 3,
  "name": "Link Extension",
  "version": "1.0",
  "description": "Minimal extension to save and view links via backend API",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:5000/*"
  ]
}